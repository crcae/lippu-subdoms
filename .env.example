# Admin panel password (requerido para acceder a /admin y /api/manage)
ADMIN_PASSWORD=cambia-esta-contrasena

# GitHub — para actualizar events.json y triggerear redeploys automáticos
# Crear en: https://github.com/settings/tokens (scope: repo)
GITHUB_TOKEN=
GITHUB_REPO=tu-usuario/lippu-subdoms

# GoDaddy — para crear CNAME records automáticamente
# Crear en: https://developer.godaddy.com/keys
GODADDY_API_KEY=
GODADDY_API_SECRET=

# Vercel — para agregar dominios al proyecto automáticamente
# Crear en: https://vercel.com/account/tokens
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=   # Solo si tu proyecto está en un team (dejar vacío si es cuenta personal)
